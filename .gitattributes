# Forzar LF en todos los archivos de texto — evita que GitHub Desktop convierta a CRLF
* text=auto eol=lf

# Explícito para los tipos principales
*.js    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# Binarios — sin conversión
*.png   binary
*.zip   binary
*.ico   binary
